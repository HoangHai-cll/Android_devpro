<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDFDFD">

    <!-- 1. Ảnh lớn phía trên -->
    <ImageView
        android:id="@+id/imgDetail"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:scaleType="centerCrop"
        android:src="@drawable/img_banhmy"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. Nút Back (Hình tròn trắng) -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_margin="20dp"
        android:background="@drawable/bg_item_food"
        android:elevation="4dp"
        android:padding="12dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 3. Nút Favorite (Hình tròn trắng) -->
    <ImageView
        android:id="@+id/btnFav"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_margin="20dp"
        android:background="@drawable/bg_item_food"
        android:elevation="4dp"
        android:padding="10dp"
        android:src="@drawable/ic_heart_outline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 4. Khung nội dung trắng bo góc đè lên ảnh một chút -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-30dp"
        android:background="@drawable/bg_item_food"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgDetail">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bánh mỳ "
                android:textColor="@android:color/black"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Bánh mì Hà Nội thường chỉ có một lớp bơ thơm ngon và pate gan, cùng ruốc, jambon, xá xíu, vài lát giò, chả thái mỏng. Rau ăn kèm thường gồm rau mùi và dưa chuột. Sốt thường là tương ớt xay kiểu truyền thống có vị cay xé lưỡi đặc trưng. Khi có dịp du lịch Hà Nội, bạn đừng quên thưởng thức đặc sản này nhé."
                android:textColor="#8E8E8E"
                android:lineSpacingExtra="4dp"
                android:textSize="14sp" />

            <!-- Thông số phụ (Thời gian, Độ khó, Khẩu phần) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- Block thời gian -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/bg_item_food"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_time"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thời gian chờ"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                    <TextView
                        android:id="@+id/tvDetailTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30 mins"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/bg_item_food"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_star"
                        app:tint="#8E8E8E"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Độ khó "
                        android:textSize="11sp"
                        android:layout_marginTop="8dp"/>
                    <TextView
                        android:id="@+id/tvDetailDifficulty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trung bình"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"/>
                </LinearLayout>

                <!-- 3. Servings (Khẩu phần) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/bg_item_food"
                    android:padding="12dp"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/img_servings"
                        app:tint="#8E8E8E"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Khẩu phần"
                        android:textSize="11sp"
                        android:layout_marginTop="8dp"/>
                    <TextView
                        android:id="@+id/tvDetailServings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 người"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"/>
                </LinearLayout>

            </LinearLayout>

            <!-- 5. Tiêu đề Ingredients -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Thành phần "
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 6. Card hiển thị nguyên liệu (Ví dụ: Salmon) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F8F8F8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_banhmy"
                        android:background="@drawable/bg_item_food"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nguyên liệu chính"
                            android:textColor="@android:color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 cái"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Các nhãn Protein, Fat nhỏ bên phải -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_item_food"
                        android:backgroundTint="#E1F5FE"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="Bột"
                        android:textSize="10sp"
                        android:textColor="#03A9F4" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 7. Nút Rate Recipe (Nút đen bo tròn to) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRateRecipe"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/cardview_dark_background"
                android:text="Đánh giá công thức "
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"

                app:icon="@drawable/ic_star"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>